{
  "version": 6,
  "configurePresets": [
    {
      "name": "ninja-multi",
      "displayName": "Ninja Multi-Config",
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": false
      }
    },
    {
      "name": "dev",
      "inherits": "ninja-multi",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "BUILD_TESTING": true
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "displayName": "Dev",
      "configurePreset": "dev",
      "configuration": "Debug"
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "configurePreset": "ninja-multi",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "displayName": "Release",
      "configurePreset": "ninja-multi",
      "configuration": "Release"
    }
  ],
  "workflowPresets": [
    {
      "name": "release",
      "displayName": "Release Workflow",
      "steps": [
        {
          "type": "configure",
          "name": "ninja-multi"
        },
        {
          "type": "build",
          "name": "release"
        }
      ]
    }
  ]
}